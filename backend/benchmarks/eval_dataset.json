[
  {"id":"vi-01","language":"vi","text":"Hôm nay mình rất vui vì công việc tiến triển tốt.","primary_emotion":"joy","valence":0.78,"energy":0.68,"stress":0.14},
  {"id":"vi-02","language":"vi","text":"Mình biết ơn vì gia đình đã luôn ở bên.","primary_emotion":"gratitude","valence":0.72,"energy":0.4,"stress":0.12},
  {"id":"vi-03","language":"vi","text":"Mình thấy tự hào vì đã vượt qua được tuần khó này.","primary_emotion":"pride","valence":0.68,"energy":0.7,"stress":0.18},
  {"id":"vi-04","language":"vi","text":"Tối nay mình khá bình yên và dễ thở hơn.","primary_emotion":"calm","valence":0.5,"energy":0.22,"stress":0.08},
  {"id":"vi-05","language":"vi","text":"Xong deadline rồi nên mình nhẹ nhõm hơn nhiều.","primary_emotion":"relief","valence":0.46,"energy":0.34,"stress":0.18},
  {"id":"vi-06","language":"vi","text":"Dù khó nhưng mình vẫn còn hy vọng mọi thứ sẽ khá hơn.","primary_emotion":"hope","valence":0.4,"energy":0.5,"stress":0.24},
  {"id":"vi-07","language":"vi","text":"Mình buồn và thất vọng về bản thân hôm nay.","primary_emotion":"sadness","valence":-0.58,"energy":0.24,"stress":0.34},
  {"id":"vi-08","language":"vi","text":"Mình thấy rất cô đơn và không ai hiểu mình.","primary_emotion":"loneliness","valence":-0.64,"energy":0.18,"stress":0.44},
  {"id":"vi-09","language":"vi","text":"Cả ngày như trống rỗng và hơi tê liệt.","primary_emotion":"emptiness","valence":-0.72,"energy":0.08,"stress":0.38},
  {"id":"vi-10","language":"vi","text":"Mình lo lắng và bất an về kỳ thi sắp tới.","primary_emotion":"anxiety","valence":-0.42,"energy":0.72,"stress":0.78},
  {"id":"vi-11","language":"vi","text":"Deadline dồn dập làm mình ngộp và quá tải.","primary_emotion":"overwhelm","valence":-0.5,"energy":0.82,"stress":0.88},
  {"id":"vi-12","language":"vi","text":"Mình rất bực bội và ức chế vì bị đổ lỗi.","primary_emotion":"anger","valence":-0.58,"energy":0.76,"stress":0.74},
  {"id":"vi-13","language":"vi","text":"Mình mệt, kiệt sức và thiếu ngủ nhiều ngày rồi.","primary_emotion":"exhaustion","valence":-0.34,"energy":0.12,"stress":0.46},
  {"id":"vi-14","language":"vi","text":"Mình hơi buồn nhưng vẫn còn hy vọng.","primary_emotion":"hope","valence":0.02,"energy":0.42,"stress":0.34},
  {"id":"vi-15","language":"vi","text":"Mình vui nhưng cũng lo lắng về bước tiếp theo.","primary_emotion":"anxiety","valence":0.02,"energy":0.62,"stress":0.52},
  {"id":"vi-16","language":"vi","text":"Mình cô đơn và mệt nên chỉ muốn im lặng.","primary_emotion":"loneliness","valence":-0.58,"energy":0.14,"stress":0.42},
  {"id":"vi-17","language":"vi","text":"Hôm nay mọi thứ bình thường, không quá tốt cũng không quá tệ.","primary_emotion":"neutral","valence":0.0,"energy":0.4,"stress":0.18},
  {"id":"vi-18","language":"vi","text":"Mình nhẹ nhõm và biết ơn sau khi nói chuyện với mẹ.","primary_emotion":"gratitude","valence":0.62,"energy":0.36,"stress":0.14},
  {"id":"vi-19","language":"vi","text":"Mình áp lực nhưng vẫn cố gắng giữ bình tĩnh.","primary_emotion":"overwhelm","valence":-0.18,"energy":0.56,"stress":0.62},
  {"id":"vi-20","language":"vi","text":"Mình thấy có chút hy vọng sau một ngày nặng nề.","primary_emotion":"hope","valence":0.12,"energy":0.34,"stress":0.28},

  {"id":"zh-01","language":"zh","text":"今天我很开心，事情进展得不错。","primary_emotion":"joy","valence":0.78,"energy":0.68,"stress":0.14},
  {"id":"zh-02","language":"zh","text":"我很感谢家人一直支持我。","primary_emotion":"gratitude","valence":0.72,"energy":0.4,"stress":0.12},
  {"id":"zh-03","language":"zh","text":"我为自己挺过这周感到自豪。","primary_emotion":"pride","valence":0.68,"energy":0.7,"stress":0.18},
  {"id":"zh-04","language":"zh","text":"今晚我终于平静了一些。","primary_emotion":"calm","valence":0.5,"energy":0.22,"stress":0.08},
  {"id":"zh-05","language":"zh","text":"事情结束后我松了一口气。","primary_emotion":"relief","valence":0.46,"energy":0.34,"stress":0.18},
  {"id":"zh-06","language":"zh","text":"虽然很难，但我还是有一点希望。","primary_emotion":"hope","valence":0.4,"energy":0.5,"stress":0.24},
  {"id":"zh-07","language":"zh","text":"我今天很难过，也对自己很失望。","primary_emotion":"sadness","valence":-0.58,"energy":0.24,"stress":0.34},
  {"id":"zh-08","language":"zh","text":"我觉得很孤独，没有人真正理解我。","primary_emotion":"loneliness","valence":-0.64,"energy":0.18,"stress":0.44},
  {"id":"zh-09","language":"zh","text":"整个人都很空虚，好像麻木了。","primary_emotion":"emptiness","valence":-0.72,"energy":0.08,"stress":0.38},
  {"id":"zh-10","language":"zh","text":"我最近很焦虑，也一直很担心。","primary_emotion":"anxiety","valence":-0.42,"energy":0.72,"stress":0.78},
  {"id":"zh-11","language":"zh","text":"压力一下子全压过来，我有点崩溃。","primary_emotion":"overwhelm","valence":-0.5,"energy":0.82,"stress":0.88},
  {"id":"zh-12","language":"zh","text":"我真的很生气，也很委屈。","primary_emotion":"anger","valence":-0.58,"energy":0.76,"stress":0.74},
  {"id":"zh-13","language":"zh","text":"我太累了，像被掏空了一样。","primary_emotion":"exhaustion","valence":-0.34,"energy":0.12,"stress":0.46},
  {"id":"zh-14","language":"zh","text":"我有点难过，但还是保留希望。","primary_emotion":"hope","valence":0.02,"energy":0.42,"stress":0.34},
  {"id":"zh-15","language":"zh","text":"我开心，但也担心下一步怎么办。","primary_emotion":"anxiety","valence":0.02,"energy":0.62,"stress":0.52},
  {"id":"zh-16","language":"zh","text":"我很孤独，也很累，只想安静。","primary_emotion":"loneliness","valence":-0.58,"energy":0.14,"stress":0.42},
  {"id":"zh-17","language":"zh","text":"今天就很普通，没有特别好也没有特别糟。","primary_emotion":"neutral","valence":0.0,"energy":0.4,"stress":0.18},
  {"id":"zh-18","language":"zh","text":"和妈妈聊完后，我既感激又放松。","primary_emotion":"gratitude","valence":0.62,"energy":0.36,"stress":0.14},
  {"id":"zh-19","language":"zh","text":"我压力很大，但还是努力保持冷静。","primary_emotion":"overwhelm","valence":-0.18,"energy":0.56,"stress":0.62},
  {"id":"zh-20","language":"zh","text":"经历很沉重的一天后，我还有一点希望。","primary_emotion":"hope","valence":0.12,"energy":0.34,"stress":0.28}
]
